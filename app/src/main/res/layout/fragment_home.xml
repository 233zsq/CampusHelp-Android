<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_primary"
        android:padding="@dimen/page_margin"
        android:text="@string/app_slogan"
        android:textColor="@color/white"
        android:textSize="@dimen/text_body" />

    <!-- 筛选栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/page_margin"
        android:paddingVertical="10dp">

        <!-- 类型筛选 -->
        <LinearLayout
            android:id="@+id/filter_type_group"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filter_all"
                style="@style/FilterChip"
                android:layout_marginEnd="6dp"
                android:text="全部" />

            <TextView
                android:id="@+id/filter_express"
                style="@style/FilterChip"
                android:layout_marginEnd="6dp"
                android:text="跑腿" />

            <TextView
                android:id="@+id/filter_group"
                style="@style/FilterChip"
                android:layout_marginEnd="6dp"
                android:text="拼单" />

            <TextView
                android:id="@+id/filter_secondhand"
                style="@style/FilterChip"
                android:text="二手" />
        </LinearLayout>

        <!-- 可接单开关 -->
        <LinearLayout
            android:id="@+id/filter_available"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="可接单"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_caption" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_available"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="@dimen/page_margin_small" />

</LinearLayout>
